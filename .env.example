# ── Supabase (client-side, חשוף לדפדפן) ───────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOi...

# ── Supabase service role (server-side בלבד, לעולם לא ב-NEXT_PUBLIC_*)
# נמצא ב-Supabase Dashboard → Settings → API → service_role
# משמש רק את ה-cron route כדי לעקוף RLS
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...

# ── Cron של ימי הולדת ─────────────────────────────────────────────
# מחרוזת אקראית; Vercel מצרף אותה כ-Authorization: Bearer <secret>
CRON_SECRET=some-long-random-string

# ── Resend (שליחת מיילים) ─────────────────────────────────────────
RESEND_API_KEY=re_xxxxxxxxxxxx

# כתובת השולח. ללא דומיין מאומת ב-Resend השאר onboarding@resend.dev —
# Resend יאפשר לשלוח רק לאימייל שרשום בחשבון Resend עצמו (ADMIN_EMAIL).
RESEND_FROM_EMAIL=onboarding@resend.dev

# הנמען של מייל ימי הולדת היומי. חייב להיות זהה לאימייל בעל חשבון Resend
# (כל עוד אין דומיין מאומת).
ADMIN_EMAIL=client@example.com

# ── כתובת הפרויקט בפרודקשן ────────────────────────────────────────
# מופיעה כ-CTA "פתח את מסך הלקוחות" במייל היומי. אם לא מוגדר —
# המייל יישלח בלי כפתור (לא קורס).
NEXT_PUBLIC_SITE_URL=https://avihu-crm.vercel.app

# ── seed script בלבד (לטעינת נתוני דמו, לא בפרודקשן) ──────────────
# SEED_EMAIL=your-supabase-user@example.com
# SEED_PASSWORD=your-supabase-user-password
